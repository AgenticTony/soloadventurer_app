AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_USER_POOL_ID=us-east-1_XXXXXXXX
AWS_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXX
AWS_IDENTITY_POOL_ID=us-east-1:XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
API_BASE_URL_DEV=https://api.soloadventurer.com/dev
API_BASE_URL_STAGING=https://api.soloadventurer.com/staging
API_BASE_URL_PROD=https://api.soloadventurer.com/prod
OAUTH_CALLBACK_URL=soloadventurer://callback
OAUTH_SIGN_OUT_URL=soloadventurer://signout
AWS_CLOUDWATCH_LOG_GROUP=/aws/cognito/userpools
AWS_CLOUDWATCH_LOG_STREAM=default
ENABLE_DETAILED_LOGS=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_CRASH_REPORTING=true
ENABLE_ANALYTICS=false
CACHE_MAX_SIZE_MB=100
CACHE_EXPIRATION_DAYS=7
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Base URL for the OpenAI instance (default is https://api.openai.com/v1)
# OpenAI: https://api.openai.com/v1
# Ollama (example): http://localhost:11434/v1
# OpenRouter: https://openrouter.ai/api/v1
BASE_URL=https://openrouter.ai/api/v1

# For OpenAI: https://help.openai.com/en/articles/4936850-where-do-i-find-my-openai-api-key
# For OpenRouter: https://openrouter.ai/keys
# For Ollama, no need to set this unless you specifically configured an API key
LLM_API_KEY=your_llm_api_key

# Get your Open AI API Key by following these instructions -
# https://help.openai.com/en/articles/4936850-where-do-i-find-my-openai-api-key
# Even if using OpenRouter, you still need to set this for the embedding model.
# No need to set this if using Ollama.
OPENAI_API_KEY=your_openai_api_key

# The LLM you want to use for the reasoner (o3-mini, R1, QwQ, etc.).
# Example: o3-mini
# Example: deepseek-r1:7b-8k
REASONER_MODEL=gpt-4

# The LLM you want to use for the primary agent/coder.
# Example: gpt-4o-mini
# Example: qwen2.5:14b-instruct-8k
PRIMARY_MODEL=gpt-4

# Embedding model you want to use
# Example for Ollama: nomic-embed-text
# Example for OpenAI: text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-small

# Google Places API
# Get your API key from: https://console.cloud.google.com/
# Enable "Places API" from the API library
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Viator Transactional API
# Get your API key from: https://docs.viator.com/partner-api/technical/
VIATOR_API_KEY=your_viator_api_key