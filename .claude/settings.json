{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(./**)",
      "Write(./**)",
      "Edit(./**)",
      "Glob(./**)",
      "Grep(./**)",
      "Bash",
      "WebFetch(domain:*)",
      "WebSearch",
      "mcp__context7",
      "mcp__context7__*",
      "mcp__ref",
      "mcp__ref__*",
      "mcp__supabase",
      "mcp__supabase__*",
      "mcp__dart__*",
      "mcp__plugin_playwright_playwright__*"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use.js\""
          }
        ]
      }
    ]
  }
}
